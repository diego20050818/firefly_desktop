   "source": [
    "import random\n",
    "guess = random.randint(0,100)\n",
    "count = 0\n",
    "\n",
    "while True:\n",
    "    user:int = int(input(\"猜数字：\"))\n",
    "    count += 1\n",
    "\n",
    "    if user < guess:\n",
    "        print(\"猜小了\")\n",
    "    elif user > guess:\n",
    "        print(\"猜大了\")\n",
    "    else:\n",
    "        print(f\"猜对了！就是{guess},你用了{count}次\")\n",
    "        break"
   ]
  }
 ],
